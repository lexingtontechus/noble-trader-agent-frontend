// Prisma schema — PostgreSQL via Supabase for persistent production data.
// On Vercel, DATABASE_URL must point to a Supabase PostgreSQL connection string.
// Tables use ta_* prefix to avoid conflicts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A single analysis run — one button press from the user.
model AnalysisRun {
  id          String   @id @default(cuid())
  userId      String   @default("default")
  status      String   @default("pending") // pending | running | completed | failed
  results     String?  // JSON stringified
  positions   String?  // JSON stringified
  correlation String?  // JSON stringified
  optimizer   String?  // JSON stringified
  regimes     String?  // JSON stringified
  // Phase 2: New fields
  strategySignals String? // JSON stringified - per-symbol strategy signals
  riskAnalysis    String? // JSON stringified - per-symbol risk analysis
  kellySizes      String? // JSON stringified - per-symbol Kelly sizing
  // Phase 3: Validation summary
  validationSummary String? // JSON stringified — per-symbol validation results
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trades TradeRecommendation[]

  @@map("ta_analysis_run")
}

/// Individual trade recommendation produced by an analysis run.
model TradeRecommendation {
  id            String       @id @default(cuid())
  analysisId    String
  analysis      AnalysisRun  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  symbol        String
  side          String       // buy | sell
  orderType     String       // market | limit
  qty           Float
  limitPrice    Float?
  timeInForce   String       @default("day") // day | gtc
  priority      Int          @default(0)     // 0=highest
  reason        String?
  status        String       @default("pending") // pending | approved | blocked | executing | filled | failed | cancelled
  alpacaOrderId String?
  errorMessage  String?
  // Phase 2: New fields for enhanced pipeline
  regime        String?      // HMM regime label (bullish/bearish/neutral/crisis/volatile)
  regimeLabel   String?      // Human-readable regime name
  strategySignal String?     // long | short | flat
  strategyConfidence Float?  // 0-1 confidence score
  kellyFraction Float?       // Kelly optimal fraction
  kellySize     Float?       // Position size from Kelly ($)
  riskScore     Float?       // Risk score from analysis
  varDaily      Float?       // Daily Value-at-Risk
  cvarDaily     Float?       // Daily CVaR
  // Phase 3: Walk-forward validation fields
  validationStatus  String?  // pending | validating | passed | failed | error
  validationScore   Float?   // 0-1 composite score from walk-forward validation
  validationDetails String?  // JSON stringified — full backtest results
  validatedAt       DateTime? // When validation was run
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("ta_trade_recommendation")
}

/// Orders that need to be scheduled (e.g. after market open, after sells clear)
model ScheduledOrder {
  id              String    @id @default(cuid())
  userId          String    @default("default")
  symbol          String
  side            String    // buy | sell
  orderType       String    // market | limit
  qty             Float
  limitPrice      Float?
  timeInForce     String    @default("gtc")
  reason          String?
  status          String    @default("queued") // queued | scheduled | executing | filled | failed | cancelled
  scheduleAt      DateTime?
  dependsOnOrders String?   // JSON array of Alpaca order IDs
  alpacaOrderId   String?
  errorMessage    String?
  attempts        Int       @default(0)
  maxAttempts     Int       @default(5)
  lastAttemptAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("ta_scheduled_order")
}

/// Telegram notification log
model TelegramNotification {
  id          String   @id @default(cuid())
  chatId      String
  message     String
  messageType String   @default("trade_report") // trade_report | execution_summary | schedule_reminder | tda_alert | early_warning
  success     Boolean
  error       String?
  createdAt   DateTime @default(now())

  @@map("ta_telegram_notification")
}

/// TDA scan result — one scan of a symbol's topological features
model TDAScanResult {
  id                      String   @id @default(cuid())
  symbol                  String
  anomalyScore            Float?   // TDA anomaly score
  regimeChangeProbability Float?   // Probability of regime change
  betti0                  Int?     // Betti-0 (connected components)
  betti1                  Int?     // Betti-1 (loops)
  totalEntropy            Float?   // Combined persistence entropy
  featureVector           String?  // JSON array — 10-dim TDA feature vector
  alertTriggered          Boolean  @default(false) // Did this scan trigger an alert?
  alertLevel              String?  // none | low | medium | high | critical
  source                  String?  // fastapi | local
  scanResults             String?  // JSON stringified — full TDA response
  createdAt               DateTime @default(now())

  @@map("ta_tda_scan_result")
}

/// Early warning alert triggered by TDA regime change detection
model EarlyWarningAlert {
  id                String   @id @default(cuid())
  symbol            String
  alertType         String   // regime_change | anomaly_spike | betti_shift | entropy_surge
  alertLevel        String   // low | medium | high | critical
  anomalyScore      Float?
  regimeChangeProb  Float?
  betti0Before      Int?
  betti0After       Int?
  betti1Before      Int?
  betti1After       Int?
  message           String?  // Human-readable alert message
  telegramSent      Boolean  @default(false)
  telegramChatId    String?
  acknowledged      Boolean  @default(false)
  scanResultId      String?  // Reference to the triggering TDAScanResult
  createdAt         DateTime @default(now())

  @@map("ta_early_warning_alert")
}
